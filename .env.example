# OpenRouter API Configuration
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
VITE_SITE_URL=https://plantdoctor.ai
VITE_SITE_NAME=Plant Doctor AI Assistant

# Instructions:
# 1. Copy this file to .env
# 2. Get your API key from https://openrouter.ai
# 3. Replace 'your_openrouter_api_key_here' with your actual API key
# 4. Add VITE_HUGGING_FACE_API_KEY if needed for Hugging Face
# 5. Restart your development server

VITE_HUGGING_FACE_API_KEY=your_hugging_face_api_key_here